# Required: set one AI provider key + its model variable.
# Priority when multiple keys are set: Groq > Anthropic > OpenAI.
# GROQ_API_KEY=YOUR_GROQ_API_KEY
# GROQ_MODEL=groq:llama-3.3-70b-versatile   # recommended; openai/gpt-oss-120b is a reasoning model incompatible with structured output

# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# ANTHROPIC_MODEL=anthropic:claude-sonnet-4-6

# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# OPENAI_MODEL=openai:gpt-4.1

# Required: Slack app tokens (get from api.slack.com/apps after app install)
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Analytics database (matches docker-compose.yml db service)
DATABASE_URL=postgresql://analyst_ro:analyst_ro@localhost:5432/analytics
SQL_STATEMENT_TIMEOUT_MS=10000
SQL_HARD_ROW_CAP=50000
SQL_HARD_RESULT_BYTES=5242880

# LLM behavior
LLM_TIMEOUT_S=60
CONTEXT_OVERFLOW_THRESHOLD_TOKENS=100000
COMPRESSION_MODEL=
AGENT_WORKER_THREADS=1

# Langfuse observability (generate keys via localhost:3000 after docker compose up)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# OAuth (only needed for app_oauth.py)
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional: custom Slack API URL
# SLACK_API_URL=YOUR_SLACK_API_URL
